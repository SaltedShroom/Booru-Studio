{
  "name": "Booru-Studio",
  "version": "1.2.0",
  "description": "Booru Studio",
  "author": "SaltedShroom",
  "main": "src/js/electron-main.js",
  "scripts": {
    "start": "electron src/js/electron-main.js",
    "electron": "electron src/js/electron-main.js",
    "build": "node src/config/build.js",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "package": "node src/config/prepackage.js && electron-builder",
    "dist": "electron-builder --dir",
    "postinstall": "npm run rebuild-native"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.boorustudio.app",
    "productName": "Booru Studio",
    "asar": false,
    "directories": {
      "output": "build/dist"
    },
    "files": [
      "src/js/**",
      "src/assets/**",
      "src/nodejs/**",
      "!src/tests/**",
      "!src/build/**",
      "!data/**",
      "!output/**",
      "!customConfigs/**",
      "!downloads/**",
      "package.json",
      "package-lock.json"
    ],
    "releaseInfo": {
      "releaseName": "Booru Studio ${version}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SaltedShroom",
        "repo": "Booru-Studio",
        "tagNamePrefix": ""
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/assets/favicon/app.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "src/assets/favicon"
    },
    "extraFiles": [
      {
        "from": "node_modules/electron/dist",
        "to": "resources/app/node_modules/electron/dist"
      }
    ]
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "better-sqlite3": "^12.9.0",
    "chart.js": "^4.5.1",
    "cheerio": "^1.2.0",
    "codemirror": "^5.65.2",
    "electron-updater": "^6.8.3",
    "http-proxy-agent": "^7.0.0",
    "https-proxy-agent": "^7.0.2",
    "jquery": "^3.7.1",
    "justifiedGallery": "^3.8.1",
    "monaco-editor": "^0.53.0",
    "mosaic-node-generator": "^0.0.1",
    "odometer": "^0.4.8",
    "photosaic": "^0.2.1",
    "puppeteer": "^24.35.0",
    "select2": "^4.1.0-rc.0",
    "serve-handler": "^6.1.5",
    "sharp": "^0.34.5",
    "socks-proxy-agent": "^8.0.2"
  },
  "devDependencies": {
    "clean-css": "^5.3.2",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^2.0.3",
    "fs-extra": "^11.1.1",
    "glob": "^10.4.1",
    "html-minifier-terser": "^7.0.0",
    "javascript-obfuscator": "^4.0.0",
    "terser": "^5.20.1"
  }
}
